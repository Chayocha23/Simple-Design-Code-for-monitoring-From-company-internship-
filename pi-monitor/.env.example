# =============================================
# Pi Monitor - Environment Variables Template
# คัดลอกไฟล์นี้แล้วเปลี่ยนชื่อเป็น .env
# และใส่ค่าจริงลงไป (ห้าม commit ไฟล์ .env)
# =============================================

# --- ตั้งค่า Interval การตรวจสอบ ---
CHECK_INTERVAL_MINUTES=5

# --- Google Sheets ---
GOOGLE_SHEET_ID= 1LA-E3TvMk7Zg7UV4O_AuWIcR1LNtxJWRnD_zs7aH3ag #your_google_sheet_id_here (between d & edit)
GOOGLE_SERVICE_ACCOUNT_EMAIL= chayochat@gmail.com #your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SHEET_NAME=StatusSheet

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_OR_GROUP_ID=your_user_or_group_id_here

# --- Email (Nodemailer / Gmail) ---
EMAIL_HOST=chayochat@gmail.com
EMAIL_PORT=587
EMAIL_USER=chayochat@gmail.com
EMAIL_PASS=blinkchayocha23
EMAIL_TO=alert_recipient@gmail.com

# --- SSH ไปยัง Raspberry Pi แต่ละตัว ---
# รูปแบบ: PI_<NAME>_HOST, PI_<NAME>_USER, PI_<NAME>_PASS หรือ PI_<NAME>_KEY_PATH
PI_DICUT_HOST=192.168.1.101
PI_DICUT_USER=pi
PI_DICUT_PASS=raspberry

PI_ROLLFOLD_HOST=192.168.1.102
PI_ROLLFOLD_USER=pi
PI_ROLLFOLD_PASS=raspberry

PI_SHEETFOLD_HOST=192.168.1.103
PI_SHEETFOLD_USER=pi
PI_SHEETFOLD_PASS=raspberry

PI_TRAY_HOST=192.168.1.104
PI_TRAY_USER=pi
PI_TRAY_PASS=raspberry

# --- SSH Command ที่ Pi จะรันหลัง Reboot ---
# สคริปต์ที่เปิดหน้าจอ Queue บน Pi
PI_STARTUP_SCRIPT=/home/pi/start_display.sh
